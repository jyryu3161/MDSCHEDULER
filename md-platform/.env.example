# ── MD Platform environment (copy to .env) ─────────────────────────────────
APP_PORT=8888
DEFAULT_ADMIN_ID=csbl
DEFAULT_ADMIN_PASSWORD=csbl
DEFAULT_MD_LENGTH_NS=50
DEFAULT_TOP_N_POSES=3

# Storage / DB / Queue
STORAGE_ROOT=/app/storage
DATABASE_URL=postgresql+psycopg://mduser:mdpass@db:5432/mdplatform
REDIS_URL=redis://redis:6379/0
QUEUE_BACKEND=auto
INTERNAL_API_TOKEN=internal-worker-token-change-me

# Uploads / quota
MAX_UPLOAD_SIZE_GB=10
RETENTION_DAYS=30

# GPU
GPU_ASSIGNMENT_MODE=one_job_per_gpu
NUM_GPUS=auto

# MD engine + force-field toolchain (PDR §5.4)
MD_ENGINE=auto
MD_MOCK_SPEEDUP=2000
TRAJECTORY_OUTPUT_PS=100
# Protein force field + water model. Default ff19SB + OPC (recommended for binding studies;
# ff19SB is parameterized against OPC). The VALUE is the GROMACS force-field PORT DIRECTORY name
# (`gmx pdb2gmx -ff`); the ff19SB port ships as "amber19sb.ff", so use "amber19sb" (the literal
# "ff19SB" would not match the dir and would silently fall back). Requires the ff19SB port with
# OPC in its watermodels.dat; when it is NOT installed the worker auto-detects this and falls back
# to the stock pair below, logging a warning — so a plain GROMACS install still runs out of the box.
PROTEIN_FORCE_FIELD=amber19sb
WATER_MODEL=opc
PROTEIN_FORCE_FIELD_FALLBACK=amber14sb
WATER_MODEL_FALLBACK=tip3p
FORCEFIELD_AUTOFALLBACK=true
LIGAND_FORCE_FIELD=gaff2
LIGAND_CHARGE_METHOD=am1bcc

# Solvation/equilibration protocol (Tier-3 conditions for peptide–compound binding)
BOX_PADDING_NM=1.2
NVT_STEPS=50000     # 100 ps NVT equilibration (dt=0.002 ps)
NPT_STEPS=125000    # 250 ps NPT equilibration

# Input policy (PDR §6)
REQUIRE_LIGAND_CHEMISTRY=true
ALLOW_SMILES_INPUT=true
ALLOW_MEEKO_MAPPING_INPUT=true

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=480

# Worker
BACKEND_URL=http://backend:8000
MDP_TEMPLATE_DIR=/app/md-env/templates/gromacs
WORKER_GPU_ID=0

# ── Local dev (no Docker) overrides ─────────────────────────────────────────
# STORAGE_ROOT=./storage
# DATABASE_URL=sqlite:///./storage/md_platform.db
# QUEUE_BACKEND=local
# MD_ENGINE=mock
